{
  "name": "fullstack-boilerplate-monorepo",
  "private": true,
  "scripts": {
    "postinstall": "bun run packages/scripts/src/generate-app-config-paths.ts",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check-types": "turbo run check-types",
    "changeset": "bunx changeset",
    "changeset:version": "bunx changeset version && bun run repo-scripts sync-expo-versions",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "preflight": "echo \"Preflight checks placeholder\" && exit 0",
    "setup-worktree": "bun run repo-scripts setup-worktree"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@expo-up/cli": "^0.1.7",
    "prettier": "^3.6.0",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "turbo": "^2.8.10"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.6",
  "engines": {
    "node": ">=18"
  },
  "resolutions": {
    "lightningcss": "1.30.1",
    "@expo-up/core": "latest"
  }
}
